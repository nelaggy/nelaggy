---
import Layout from "../layouts/Layout.astro";
import cv from "../assets/cv.pdf";
import { ClientRouter } from "astro:transitions";
---

<Layout>
    <iframe title="cv" src={cv+"#toolbar=0"} width="100%" height="100%"  class="aspect-square w-full"></iframe>
    <p>or download it <a href={cv} class="text-blue-800 hover:underline hover:cursor-pointer" target="_blank">here</a></p>
</Layout>

<ClientRouter />